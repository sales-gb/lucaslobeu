# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts


# claude
/.claude
/.claude**

# sqlite — databases and WAL/SHM files are runtime state, never source
*.db
*.db-shm
*.db-wal

# user uploads — runtime content, not source code
/public/uploads/
.gstack/

# DB backups (gerados por scripts/clean-db.ts)
local.db.bak-*

# Cloudflare generated types (conflitam com a DOM lib — usamos src/types/cloudflare.d.ts)
worker-configuration.d.ts
.open-next/
.wrangler/
